{
  "name": "instagram-comment-activity-deleter",
  "version": "0.1.0",
  "private": true,
  "description": "Private browser automation utility for deleting your own Instagram comment activity in controlled batches.",
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "node --disable-warning=ExperimentalWarning scripts/build.mjs && node --disable-warning=ExperimentalWarning scripts/build-extension.mjs",
    "build:extension": "node --disable-warning=ExperimentalWarning scripts/build-extension.mjs",
    "check": "npm run build && npm run typecheck && npm test && node scripts/check-syntax.mjs",
    "test": "node --test",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "instagram",
    "browser-console",
    "privacy",
    "automation"
  ],
  "author": "Sinan Bolel",
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/node": "^22.15.17",
    "typescript": "^5.8.3"
  }
}
